{
  "name": "octodeck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.9",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "preact": "^10.29.0",
    "react": "file:./shims/react",
    "swr": "^2.4.1",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "oxfmt",
      "oxlint",
      "vitest related --run"
    ]
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.8.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
