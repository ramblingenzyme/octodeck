# Wrangler local secrets for `npm run dev:api`
# Copy to .dev.vars (gitignored) and fill in real values.
GITHUB_CLIENT_ID=your_github_app_client_id_here
GITHUB_CLIENT_SECRET=your_github_app_client_secret_here
ALLOWED_ORIGIN=http://localhost:5173
# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
SESSION_CRYPTO_KEY=your_32_byte_base64url_key_here
